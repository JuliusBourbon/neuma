<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_white">

    <ProgressBar
        android:id="@+id/progress_bar_learn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- MATERIAL SECTION -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_material"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_material_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TIPE MATERI"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_material_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Judul Materi"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tv_material_type"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/iv_material_media"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:layout_marginTop="24dp"
            android:scaleType="fitCenter"
            app:layout_constraintTop_toBottomOf="@id/tv_material_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_material_content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Isi konten materi di sini..."
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:layout_marginTop="24dp"
            android:lineSpacingExtra="4dp"
            app:layout_constraintTop_toBottomOf="@id/iv_material_media"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btn_next_material"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="LANJUT"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/primary"
            app:cornerRadius="14dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- QUIZ SECTION -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_quiz"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_quiz_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UJI KEMAMPUANMU"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_question_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Pertanyaan..."
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tv_quiz_header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/iv_question_media"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:layout_marginTop="16dp"
            android:scaleType="fitCenter"
            app:layout_constraintTop_toBottomOf="@id/tv_question_text"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- For MULTIPLE_CHOICE -->
        <LinearLayout
            android:id="@+id/layout_options_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/iv_question_media"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- For TRUE_FALSE_VISUAL -->
        <LinearLayout
            android:id="@+id/layout_true_false"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:weightSum="2"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/iv_question_media"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/btn_true"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="✅ BENAR"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_white"
                android:backgroundTint="#4CAF50"
                app:cornerRadius="14dp" />

            <Button
                android:id="@+id/btn_false"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="❌ SALAH"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_white"
                android:backgroundTint="#F44336"
                app:cornerRadius="14dp" />
        </LinearLayout>

        <!-- For SIGN_PRACTICE Placeholder -->
        <Button
            android:id="@+id/btn_simulate_camera"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="SIMULASIKAN DETEKSI KAMERA"
            android:textColor="@color/text_white"
            android:backgroundTint="@color/divider"
            app:cornerRadius="14dp"
            android:layout_marginTop="24dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/layout_true_false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btn_submit_answer"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="SUBMIT"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/primary"
            app:cornerRadius="14dp"
            app:layout_constraintBottom_toTopOf="@id/btn_skip_question"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_skip_question"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="LEWATI SOAL INI"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
