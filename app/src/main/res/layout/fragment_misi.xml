<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/misi_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_white">

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_misi"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="16dp">

            <!-- Judul Halaman -->
            <TextView
                android:id="@+id/tv_misi_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Misi"
                android:textColor="@color/primary"
                android:textSize="30sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tv_misi_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Taklukkan misi untuk mendapatkan hadiah!"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="28dp" />

            <!-- ======================== -->
            <!-- SECTION: MISI HARIAN     -->
            <!-- ======================== -->
            <TextView
                android:id="@+id/tv_section_harian"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MISI HARIAN"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <!-- Kartu Misi Aktif 1 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_misi_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/card_background"
                android:layout_marginBottom="12dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/iv_icon_misi_1"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_launcher_foreground"
                        android:contentDescription="Ikon misi"
                        android:background="@color/primary_light"
                        android:padding="8dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tv_misi_1_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Kumpulkan 3 huruf BISINDO"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iv_icon_misi_1"
                        app:layout_constraintEnd_toStartOf="@id/tv_misi_1_progress" />

                    <ProgressBar
                        android:id="@+id/pb_misi_1"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:progress="33"
                        android:progressTint="@color/primary"
                        android:progressBackgroundTint="@color/divider"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_misi_1_title"
                        app:layout_constraintStart_toEndOf="@id/iv_icon_misi_1"
                        app:layout_constraintEnd_toStartOf="@id/tv_misi_1_progress" />

                    <TextView
                        android:id="@+id/tv_misi_1_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1/3"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginStart="10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Kartu Misi Aktif 2 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_misi_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/card_background"
                android:layout_marginBottom="12dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/iv_icon_misi_2"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_launcher_foreground"
                        android:contentDescription="Ikon misi"
                        android:background="@color/primary_light"
                        android:padding="8dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tv_misi_2_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Belajar BISINDO selama 5 menit"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iv_icon_misi_2"
                        app:layout_constraintEnd_toStartOf="@id/tv_misi_2_progress" />

                    <ProgressBar
                        android:id="@+id/pb_misi_2"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:progress="60"
                        android:progressTint="@color/primary"
                        android:progressBackgroundTint="@color/divider"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_misi_2_title"
                        app:layout_constraintStart_toEndOf="@id/iv_icon_misi_2"
                        app:layout_constraintEnd_toStartOf="@id/tv_misi_2_progress" />

                    <TextView
                        android:id="@+id/tv_misi_2_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3/5"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginStart="10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Kartu Misi Aktif 3 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_misi_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/card_background"
                android:layout_marginBottom="12dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/iv_icon_misi_3"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_launcher_foreground"
                        android:contentDescription="Ikon misi"
                        android:background="@color/primary_light"
                        android:padding="8dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tv_misi_3_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Raih 10 Poin Isyarat"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iv_icon_misi_3"
                        app:layout_constraintEnd_toStartOf="@id/tv_misi_3_progress" />

                    <ProgressBar
                        android:id="@+id/pb_misi_3"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:progress="20"
                        android:progressTint="@color/primary"
                        android:progressBackgroundTint="@color/divider"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_misi_3_title"
                        app:layout_constraintStart_toEndOf="@id/iv_icon_misi_3"
                        app:layout_constraintEnd_toStartOf="@id/tv_misi_3_progress" />

                    <TextView
                        android:id="@+id/tv_misi_3_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2/10"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginStart="10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Kartu Misi Aktif 4 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_misi_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/card_background"
                android:layout_marginBottom="20dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/iv_icon_misi_4"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_launcher_foreground"
                        android:contentDescription="Ikon misi"
                        android:background="@color/primary_light"
                        android:padding="8dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tv_misi_4_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Jawab 3 tantangan tanpa salah"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iv_icon_misi_4"
                        app:layout_constraintEnd_toStartOf="@id/tv_misi_4_progress" />

                    <ProgressBar
                        android:id="@+id/pb_misi_4"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:progress="0"
                        android:progressTint="@color/primary"
                        android:progressBackgroundTint="@color/divider"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_misi_4_title"
                        app:layout_constraintStart_toEndOf="@id/iv_icon_misi_4"
                        app:layout_constraintEnd_toStartOf="@id/tv_misi_4_progress" />

                    <TextView
                        android:id="@+id/tv_misi_4_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/3"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginStart="10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Kartu Misi Terkunci 1 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_misi_locked_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/background_light"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/iv_lock_1"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_lock_lock"
                        android:contentDescription="Terkunci"
                        android:alpha="0.5" />

                    <TextView
                        android:id="@+id/tv_locked_1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Terungkap ketika 1 misi selesai"
                        android:textColor="@color/text_hint"
                        android:textSize="13sp"
                        android:layout_marginStart="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Kartu Misi Terkunci 2 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_misi_locked_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/background_light"
                android:layout_marginBottom="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/iv_lock_2"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_lock_lock"
                        android:contentDescription="Terkunci"
                        android:alpha="0.5" />

                    <TextView
                        android:id="@+id/tv_locked_2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Terungkap ketika 2 misi selesai"
                        android:textColor="@color/text_hint"
                        android:textSize="13sp"
                        android:layout_marginStart="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ======================== -->
            <!-- SECTION: AKAN DATANG     -->
            <!-- ======================== -->
            <TextView
                android:id="@+id/tv_section_upcoming"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AKAN DATANG"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/card_upcoming"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/background_light">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎯 Misi baru akan segera hadir!"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="24dp" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/card_background"
        app:elevation="12dp"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/primary"
        app:itemTextColor="@color/primary"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
